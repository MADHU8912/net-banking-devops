pipeline {
    agent any

    environment {
        DOCKER_IMAGE_BACKEND = 'nikhilabba12/netbank-backend'
        DOCKER_IMAGE_FRONTEND = 'nikhilabba12/netbank-frontend'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Check Files') {
            steps {
                bat 'dir'
                bat 'if not exist backend exit /b 1'
                bat 'if not exist frontend exit /b 1'
            }
        }

        stage('Build Backend Image') {
            steps {
                bat 'docker build -t %DOCKER_IMAGE_BACKEND%:latest backend'
            }
        }

        stage('Build Frontend Image') {
            steps {
                bat 'docker build -t %DOCKER_IMAGE_FRONTEND%:latest frontend'
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    bat 'echo %DOCKER_PASS% | docker login -u %DOCKER_USER% --password-stdin'
                }
            }
        }

        stage('Docker Push Backend') {
            steps {
                bat 'docker push %DOCKER_IMAGE_BACKEND%:latest'
            }
        }

        stage('Docker Push Frontend') {
            steps {
                bat 'docker push %DOCKER_IMAGE_FRONTEND%:latest'
            }
        }

        stage('Docker Pull Test') {
            steps {
                bat 'docker pull %DOCKER_IMAGE_BACKEND%:latest'
                bat 'docker pull %DOCKER_IMAGE_FRONTEND%:latest'
            }
        }

        stage('Build Report') {
            steps {
                bat 'echo Build successful > build-report.txt'
                bat 'echo Backend image: %DOCKER_IMAGE_BACKEND%:latest >> build-report.txt'
                bat 'echo Frontend image: %DOCKER_IMAGE_FRONTEND%:latest >> build-report.txt'
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'build-report.txt', fingerprint: true
        }
    }
}
